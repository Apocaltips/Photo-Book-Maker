{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "playInternal": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "playInternal": {
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
